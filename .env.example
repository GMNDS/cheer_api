APP_NAME="Cheer API"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.example.com

HOST=api.example.com
TRAEFIK_NETWORK=proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_TLS=true
TRAEFIK_CERTRESOLVER=letsencrypt

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=cheer_api
DB_USERNAME=cheer
DB_PASSWORD=change-this-password
DB_ROOT_PASSWORD=change-this-root-password
DB_CHARSET=utf8mb4

AUTHENTIK_BASE_URL=https://auth.example.com
AUTHENTIK_API_TOKEN=
AUTHENTIK_VERIFY_SSL=true
AUTHENTIK_CA_BUNDLE=
AUTHENTIK_APPLICATION_SLUG=cheer-api
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_REDIRECT_URI=https://api.example.com/api/auth/callback
AUTHENTIK_POST_LOGIN_REDIRECT_URI=http://localhost:5173
AUTHENTIK_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
AUTHENTIK_SCOPES="openid profile email"
AUTHENTIK_REQUIRED_SCOPES=
AUTHENTIK_USER_PATH=users
AUTHENTIK_LOCAL_USER_IDENTIFIER=uid
AUTHENTIK_VOLUNTARIO_GROUP_NAME=voluntario
AUTHENTIK_INSTITUICAO_GROUP_NAME=instituicao
AUTHENTIK_VOLUNTARIO_GROUP_UUID=
AUTHENTIK_INSTITUICAO_GROUP_UUID=

SESSION_NAME=cheer_session
SESSION_LIFETIME=7200
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax

CORS_ALLOWED_ORIGIN=http://localhost:5173
CORS_ALLOWED_METHODS="GET, POST, OPTIONS"
CORS_ALLOWED_HEADERS="Content-Type, X-Requested-With"
CORS_ALLOW_CREDENTIALS=true
