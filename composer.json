{
    "name": "astrum/cheer_api",
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^7.0",
        "zircote/swagger-php": "^6.1"
    },
    "autoload": {
        "psr-4": {
            "Cheer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": ">=12.5.22 <13.0"
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    }
}
